CM_ BO_ 353 "Raw DRV8301 register dump on CAN ID 0x161: STATUS1_L, STATUS2_L, CONTROL1_L, CONTROL1_H, CONTROL2_L, CONTROL2_H, FLAGS, MARKER.";
CM_ SG_ 353 drv_status1_raw "Raw low byte of DRV8301 STATUS1.";
CM_ SG_ 353 drv_status2_raw "Raw low byte of DRV8301 STATUS2.";
CM_ SG_ 353 drv_control1_raw "Raw low byte of DRV8301 CONTROL1.";
CM_ SG_ 353 drv_control1_hi "Raw high byte of DRV8301 CONTROL1.";
CM_ SG_ 353 drv_control2_raw "Raw low byte of DRV8301 CONTROL2.";
CM_ SG_ 353 drv_control2_hi "Raw high byte of DRV8301 CONTROL2.";
CM_ SG_ 353 drv_flags_debug "Flags byte: bit0 ctrl1 verify, bit1 ctrl2 verify, bit2 spi ok, bit3 gate enabled, bit4 nFAULT active.";
CM_ SG_ 353 drv_ctrl1_verify_ok "Control1 write-readback verify bit.";
CM_ SG_ 353 drv_ctrl2_verify_ok "Control2 write-readback verify bit.";
CM_ SG_ 353 drv_spi_ok "SPI transaction path currently OK.";
CM_ SG_ 353 drv_gate_enabled "EN_GATE currently enabled by firmware.";
CM_ SG_ 353 drv_nfault_active "nFAULT pin is active low, so 1 means fault pin is low.";
CM_ SG_ 353 drv_frame_marker "Constant 0xA5 marker for the raw debug frame layout.";
CM_ BO_ 481 "PlatformIO/SimpleFOC motor debug frame replacing USB serial bringup telemetry.";
CM_ SG_ 481 motor_flags_debug "bit0 run_allowed, bit1 nFAULT active, bit2 global control fresh, bit3 node command fresh, bit4 section active";
CM_ SG_ 481 hall_raw_debug "Raw Hall pin state: bit0 HallA/PB6, bit1 HallB/PB7, bit2 HallC/PB11";
